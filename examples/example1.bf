
/*
    for loop that sums integers for 1 to n
    if total is greater than 5, print "success"
*/

#define THR 5

int sumIntegers(int n) {
    int total = 0; this is a comment
    for i = 1, n {
        total += i
    }
    return total
}

void main() {

    if THR < sumIntegers().print() {
        "success".print()
    } else {
        "bad".print()
    }
}